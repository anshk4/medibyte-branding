# Supabase — create a project at https://supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Settings → API → service_role). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: comma-separated emails auto-allowed as admin on first login
ADMIN_EMAILS=care@hjunicare.com

# Optional: notification email when a new lead arrives
NOTIFY_EMAIL=care@hjunicare.com
